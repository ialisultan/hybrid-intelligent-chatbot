# Streamlit UI (local: make streamlit | Docker: streamlit service)
BACKEND_URL=http://localhost:8000
STREAMLIT_PORT=8501

# Application
APP_NAME=hybrid-chatbot-intelligent-routing
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false

# Database — local dev uses SQLite (no Docker). Docker Compose sets PostgreSQL via DATABASE_URL.
# Leave DATABASE_URL unset or use the SQLite URL below for local `make run`.
# SQLITE_PATH=data/local.db
# DATABASE_URL=sqlite+aiosqlite:///data/local.db

# PostgreSQL — optional for Docker or `make postgres-up` local workflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_secret
POSTGRES_DB=chatbot
# DATABASE_URL=postgresql+asyncpg://chatbot:chatbot_secret@localhost:5432/chatbot

# LLM providers — auto selects first available key in priority order
LLM_PROVIDER=auto
EMBEDDING_PROVIDER=auto
LLM_PROVIDER_PRIORITY=openai,anthropic,google

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (chat only — no embeddings)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Google / Gemini (chat + embeddings)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004

# Vector store — faiss (local default) | qdrant (Docker profile) | pinecone (managed cloud)
VECTOR_STORE_BACKEND=faiss
VECTOR_TOP_K=5
FAISS_INDEX_PATH=data/faiss
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=
QDRANT_COLLECTION=documents
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=

# CORS — comma-separated allowed origins (production); empty + APP_DEBUG uses permissive dev mode
CORS_ORIGINS=http://localhost:8501

# API rate limiting (POST /api/v1/chat — per client IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# LangSmith tracing (optional — off by default)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=hybrid-chatbot-intelligent-routing
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_HIDE_INPUTS=false
# LANGSMITH_HIDE_OUTPUTS=false
# LANGSMITH_SAMPLING_RATE=1.0

# LangGraph / routing
CLASSIFIER_CONFIDENCE_THRESHOLD=0.7
SQL_PIPELINE_MAX_ROWS=100
CONVERSATION_HISTORY_LIMIT=10
# Conversation storage: postgres (default) | memory (tests / no DB)
CONVERSATION_REPOSITORY=postgres

# ── Docker overrides (uncomment for make up / compose) ─────────────────────
# POSTGRES_HOST=postgres
# DATABASE_URL=postgresql+asyncpg://chatbot:chatbot_secret@postgres:5432/chatbot

# FAISS in Docker (make up-faiss — default):
# VECTOR_STORE_BACKEND=faiss

# Qdrant in Docker (make up-qdrant):
# VECTOR_STORE_BACKEND=qdrant
# QDRANT_HOST=qdrant

# Pinecone in Docker (make up-pinecone — set keys above):
# VECTOR_STORE_BACKEND=pinecone
