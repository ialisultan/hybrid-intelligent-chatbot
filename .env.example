# Streamlit UI (local: make streamlit | Docker: streamlit service)
BACKEND_URL=http://localhost:8000
STREAMLIT_PORT=8501

# Application
APP_NAME=hybrid-chatbot-intelligent-routing
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=false

# PostgreSQL — local defaults (use POSTGRES_HOST=postgres for Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_secret
POSTGRES_DB=chatbot
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot_secret@localhost:5432/chatbot

# LLM providers — auto selects first available key in priority order
LLM_PROVIDER=auto
EMBEDDING_PROVIDER=auto
LLM_PROVIDER_PRIORITY=openai,anthropic,google

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (chat only — no embeddings)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Google / Gemini (chat + embeddings)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_EMBEDDING_MODEL=models/text-embedding-004

# Vector store — local: faiss | Docker: qdrant
VECTOR_STORE_BACKEND=faiss
VECTOR_TOP_K=5
FAISS_INDEX_PATH=data/faiss
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=
QDRANT_COLLECTION=documents

# Docker overrides (uncomment when using make up):
# POSTGRES_HOST=postgres
# DATABASE_URL=postgresql+asyncpg://chatbot:chatbot_secret@postgres:5432/chatbot
# VECTOR_STORE_BACKEND=qdrant
# QDRANT_HOST=qdrant

# LangGraph / routing
CLASSIFIER_CONFIDENCE_THRESHOLD=0.7
SQL_PIPELINE_MAX_ROWS=100
CONVERSATION_HISTORY_LIMIT=10
# Conversation storage: postgres (default) | memory (tests / no DB)
CONVERSATION_REPOSITORY=postgres
